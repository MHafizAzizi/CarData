# Scraper outputs
logs/
checkpoint_*.csv
*.csv

# Curated reference data — exception to the global *.csv ignore
!data/reference/motorcycles_model_types.csv
!data/reference/cars_model_types.csv

# Raw scrape output — ignore CSV files but track the category subfolders
data/raw/*
!data/raw/cars/
!data/raw/motorcycles/
data/raw/cars/*
data/raw/motorcycles/*

# Archived CSVs (post-migration) — ignore contents but track folders
data/old/*
!data/old/cars/
!data/old/motorcycles/
data/old/cars/*
data/old/motorcycles/*

# Master data (large binary — store externally)
data/master/
*.xlsx

# ML artifacts and exploratory notebooks (local only)
data/models/
notebooks/

# SQLite databases (live data — never tracked)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code session metadata
.claude/

# Local project context (living document — not for the repo)
CONTEXT.md
CONTEXT.original.md
CONTEXT_ARCHIVE.md
CONTEXT_ARCHIVE.original.md

# Variant scrape run log (transient — not reference data)
data/reference/variants_run.log
